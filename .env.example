# ----------------------------------------------------------------------------
# WIT Hub — variáveis de ambiente. Copie para .env.local e preencha.
# Sem o Supabase configurado, o app roda em MODO DEMO (dados de exemplo).
# ----------------------------------------------------------------------------

# Supabase (banco de dados)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Acesso do professor
# Código que o professor digita para entrar na área /professor.
# Sem isto, o app fica em MODO DEMO e aceita o código padrão "wit".
PROFESSOR_ACCESS_CODE=
# Segredo para assinar o cookie de sessão (gere algo aleatório e longo).
# Opcional: se vazio, é derivado do PROFESSOR_ACCESS_CODE.
AUTH_SECRET=

# Notificações por e-mail (Resend — https://resend.com)
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=WIT de IA <wit@seudominio.com>

# Atalhos do Hub (opcional — sobrescreve os links padrão)
NEXT_PUBLIC_LINK_CLASSROOM=https://classroom.google.com
NEXT_PUBLIC_LINK_DUNGEON=
NEXT_PUBLIC_LINK_CANVA=https://www.canva.com

# Protege a rota do cron (o cron do Vercel envia este token automaticamente)
CRON_SECRET=
